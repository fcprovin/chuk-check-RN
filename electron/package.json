{
  "name": "electron",
  "version": "1.0.0",
  "description": "",
  "main": "main.js",
  "homepage": "./",
  "scripts": {
    "electron:win": "electron-builder --win",
    "electron:mac": "electron-builder build --mac"
  },
  "author": "",
  "license": "ISC",
  "build": {
    "productName": "RoseConnect",
    "appId": "com.rose.connect",
    "asar": true,
    "protocols": {
      "name": "RoseConnect",
      "schemes": [
        "RoseConnect"
      ]
    },
    "files": [
      {
        "from": ".",
        "to": ".",
        "filter": [
          "main.js",
          "preload.js"
        ]
      },
      {
        "from": "dist",
        "to": "dist",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "../icons/logo.ico"
    },
    "mac": {
      "target": [
        "default"
      ]
    },
    "dmg": {
      "title": "RoseConnect"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "directories": {
      "output": "release"
    }
  },
  "devDependencies": {
    "electron-builder": "^24.13.3",
    "electron": "^31.0.2"
  }
}
